{
  "layer": "top",
  "modules-left": [
    "sway/workspaces",
    "sway/mode"
  ],
  "modules-center": [
    "sway/window"
  ],
  "modules-right": [
    "battery",
    "clock"
  ],
  "sway/window": {
    "max-length": 50
  },
  "clock": {
    "interval": 60,
    "format": "{:%H:%M}"
  },
  "battery": {
    "format": "{capacity}% {icon}",
    "format-icons": [
      "",
      "",
      "",
      "",
      ""
    ]
  }
}
