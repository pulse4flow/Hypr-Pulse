{
  "layer": "top",
  "position": "top",
  "height": 30,
  "modules-left": [
    "network",
    "pulseaudio"
  ],
  "modules-center": [
    "sway/workspaces",
    "sway/mode"
  ],
  "modules-right": [
    "keyboard-state",
    "clock"
  ],
  // right side
  "clock": {
    "format": "☁️  {:%Y年 %m月 %d日  ||  %H時 %M分}"
  },
  "keyboard-state": {
    "format": "{layout}",
    "format-icons": {
      "us": "A",
      "jp": "あ"
    }
  }
  // middle side
}
